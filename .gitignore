# =========================
# ROOT LEVEL IGNORE
# =========================

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Env files
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/

# =========================
# mindmerge-frontend (Next.js)
# =========================

# dependencies
mindmerge-frontend/node_modules/

# build outputs
mindmerge-frontend/.next/
mindmerge-frontend/out/
mindmerge-frontend/build/

# cache
mindmerge-frontend/.turbo/

# misc
mindmerge-frontend/coverage/

# next.js
mindmerge-frontend/next-env.d.ts

# =========================
# BACKEND (Python / FastAPI)
# =========================

# virtual environments
mindmerge-backend/venv/
mindmerge-backend/.venv/

# python cache
mindmerge-backend/__pycache__/
mindmerge-backend/*.pyc

# db
mindmerge-backend/*.db

# =========================
# GLOBAL FALLBACK (IMPORTANT)
# =========================

# ignore ANY node_modules anywhere
node_modules/

# ignore ANY venv anywhere
venv/
.venv/

# python cache global
__pycache__/
*.pyc

# next global
.next/

# =========================
# SECURITY
# =========================

# secrets
*.pem
*.key